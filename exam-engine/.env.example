# Exam Engine Environment Variables

PORT=8090

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE=5

# Kafka
KAFKA_BROKER=localhost:9092

# Spring Boot (for fetching questions on EXAM_BATCH_READY)
SPRING_BASE_URL=http://localhost:8080

# Worker Pool
WORKER_POOL_SIZE=10

# Rate Limiting (requests per second per candidate)
RATE_LIMIT_RPS=10

# Heartbeat
HEARTBEAT_INTERVAL=10s
HEARTBEAT_MISSES=3

# AI Grading Service
AI_GRADING_URL=http://localhost:8000
AI_GRADING_TIMEOUT=10s
AI_GRADING_RETRIES=3
AI_GRADING_PROTOCOL=rest
