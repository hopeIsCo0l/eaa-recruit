# ── React Frontend environment variables ─────────────────────────────────────
# Vite exposes only variables prefixed with VITE_ to the browser bundle.
# Copy to .env.local for local dev (Vite ignores .env.local in git).

# Backend API base URL — used by the Vite dev-server proxy.
# In production (Docker) this is not needed; Nginx proxies /api internally.
VITE_API_BASE_URL=http://localhost:8080
