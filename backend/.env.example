# ── Spring Boot environment variables ────────────────────────────────────────
# Copy to .env and source before running `./gradlew bootRun`, or pass via IDE run config.

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/recruitment
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Auth
JWT_SECRET=change-me-min-32-chars-long-secret-key-for-production

# Internal service-to-service key (exam-engine → backend callbacks)
INTERNAL_API_KEY=change-me-internal-api-key

# File storage (XAI PDF reports)
XAI_REPORTS_DIR=./reports
