# ── Docker Compose root .env ─────────────────────────────────────────────────
# Copy to .env and fill in secrets before running `docker compose up`.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=recruitment

# Spring Boot
JWT_SECRET=change-me-min-32-chars-long-secret-key-for-production
INTERNAL_API_KEY=change-me-internal-api-key

# AI Service (optional — needed only for XAI justification via Claude)
ANTHROPIC_API_KEY=
